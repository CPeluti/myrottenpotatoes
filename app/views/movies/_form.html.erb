<%= form_with model: @movie do |form| %>
  <% if form.object.errors.any? %>
    <p class="error"><% form.object.errors.full_messages.first%></p>
  <% end %>
  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>

    <%= form.label :rating %>
    <%= form.select :rating, Movie.all_ratings %>

    <%= form.label :release_date %>
    <%= form.date_select :release_date %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>